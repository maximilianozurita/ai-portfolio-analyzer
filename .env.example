# ── Base de datos ───────────────────────────────────────────────
DB_ROOT_PASSWORD=rootpassword
DB_NAME=stats
DB_USER=appuser
DB_PASSWORD=apppassword

# ── Puertos expuestos en el host ────────────────────────────────
API_PORT=5001
FRONTEND_PORT=5173

# ── URL que el browser usa para llegar a la API ─────────────────
# Cambiar si accedés desde otro dispositivo (ej. Tailscale)
PUBLIC_API_URL=http://localhost:5001

# ── AI Providers (completar al menos uno) ───────────────────────
# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI GPT — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter (modelos gratuitos disponibles) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
